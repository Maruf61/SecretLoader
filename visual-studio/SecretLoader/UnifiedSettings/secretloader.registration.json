{
  /*
   * Unified Settings registration so SecretLoader renders natively in the VS 2026 Settings UI
   * (instead of the "not migrated yet" legacy bridge). Each property binds to the VsUserSettingsRegistry
   * store at "{collection}\{name}" — the SAME store our code reads via WritableSettingsStore (collection
   * "SecretLoader"), so the new-UI editor and the plugin share one source of truth.
   */
  "properties": {
    "secretLoader.general.cliPath": {
      "type": "string",
      "default": "infisical",
      "title": "CLI path",
      "description": "The vault CLI executable (e.g. infisical, vault, doppler, aws). May be a full path.",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\CliPath" } } }
    },
    "secretLoader.general.commandTemplate": {
      "type": "string",
      "default": "{cli} export --format=json --env={env} --projectId={project}",
      "title": "Command template",
      "description": "Command that prints secrets as JSON. Placeholders: {cli} {env} {project}.",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\CommandTemplate" } } }
    },
    "secretLoader.general.jsonPath": {
      "type": "string",
      "default": "$",
      "title": "JSON path",
      "description": "Path to the secrets map in the CLI output. Default $ (root). Example: $.data.data",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\JsonPath" } } }
    },
    "secretLoader.general.listProjectsCommand": {
      "type": "string",
      "default": "",
      "title": "Project-list command",
      "description": "Optional. Command that prints a JSON list of projects for the popup's Pick button. Placeholders: {cli} {env}.",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\ListProjectsCommand" } } }
    },
    "secretLoader.general.defaultEnvironment": {
      "type": "string",
      "default": "dev",
      "title": "Default environment",
      "description": "Fallback environment when none is set on the profile / repo config.",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\DefaultEnvironment" } } }
    },
    "secretLoader.behavior.strictMode": {
      "type": "boolean",
      "default": true,
      "title": "Strict mode",
      "description": "Block the launch if secrets fail to load. (0 keys returned is still a valid success.)",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\StrictMode" } } }
    },
    "secretLoader.behavior.preferLocalVariables": {
      "type": "boolean",
      "default": true,
      "title": "Prefer local variables",
      "description": "Don't overwrite environment variables already set on the launch profile.",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\PreferLocalVariables" } } }
    },
    "secretLoader.behavior.timeoutSeconds": {
      "type": "integer",
      "default": 10,
      "title": "Execution timeout (seconds)",
      "description": "Force-kill the CLI if it hangs longer than this.",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\TimeoutSeconds" } } }
    },
    "secretLoader.behavior.blacklist": {
      "type": "string",
      "default": "",
      "title": "Blacklist",
      "description": "Key names / globs that are never injected. Separate with commas or new lines.",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\Blacklist" } } }
    },
    "secretLoader.cache.enableCache": {
      "type": "boolean",
      "default": true,
      "title": "Enable cache",
      "description": "Cache fetched secrets in memory between launches.",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\EnableCache" } } }
    },
    "secretLoader.cache.cacheDurationMinutes": {
      "type": "integer",
      "default": 5,
      "title": "Cache duration (minutes)",
      "description": "How long cached secrets stay valid.",
      "migration": { "pass": { "input": { "store": "VsUserSettingsRegistry", "path": "SecretLoader\\CacheDurationMinutes" } } }
    }
  },
  "categories": {
    "secretLoader": { "title": "SecretLoader" },
    "secretLoader.general": { "title": "General" },
    "secretLoader.behavior": { "title": "Behavior" },
    "secretLoader.cache": { "title": "Cache" }
  }
}
